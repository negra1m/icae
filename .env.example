# ICAE — Variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores conforme necessário.
# O arquivo .env nunca deve ser commitado.

# ── URLs das APIs públicas ──────────────────────────────────────────────────
SICOR_URL=https://olinda.bcb.gov.br/olinda/servico/SICOR/versao/v2/odata
TERRABRASILIS_URL=https://terrabrasilis.dpi.inpe.br/dashboard/api/v1/redis-cli
IBGE_URL=https://servicodados.ibge.gov.br/api/v1/localidades
BNDES_CSV_URL=https://dadosabertos.bndes.gov.br/dataset/102e89ec-836a-4ae0-acc7-74ac2a804c1c/resource/179950b8-b504-4cc7-b0db-9c9eed99e9ba/download/desembolsos-mensais.csv
COMEX_API_URL=https://api-comexstat.mdic.gov.br

# ── Timeouts (segundos) ────────────────────────────────────────────────────
HTTP_TIMEOUT=45

# ── Anos de referência ─────────────────────────────────────────────────────
ANO_CREDITO=2022
ANO_DESMAT_INICIO=2021
ANO_DESMAT_FIM=2022

# ── Taxa de câmbio BRL/USD (fallback quando sem API) ───────────────────────
USD_BRL=5.16

# ── Configurações do servidor ──────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=info
